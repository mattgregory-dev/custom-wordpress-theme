{
  "name": "custom-wp-theming",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tw": "tailwindcss -i src/tailwind.css -o src/public/tailwind.css --watch",
    "dev:all": "concurrently -k \"npm run dev\" \"npm run dev:tw\"",
    "build:css": "sass src/style.scss dist/assets/main.css --source-map --style=compressed",
    "build:tw": "postcss src/tailwind.css -o dist/tailwind.css",
    "build": "vite build && npm run build:css && npm run build:tw",
    "preview": "vite preview"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "sass": "^1.97.3",
    "tailwindcss": "^3.4.19",
    "vite": "^5.0.0",
    "vite-plugin-css-sourcemap": "^1.0.4"
  },
  "dependencies": {
    "gsap": "^3.14.2"
  }
}
